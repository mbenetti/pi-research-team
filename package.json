{
  "name": "pi-research-team",
  "version": "1.0.0",
  "description": "Multi-agent research pipeline and visual TUI dashboards for Pi Coding Agent",
  "type": "module",
  "keywords": [
    "pi-package"
  ],
  "dependencies": {
    "cheerio": "^1.0.0-rc.12",
    "undici": "^6.0.0",
    "yaml": "^2.3.4"
  },
  "peerDependencies": {
    "@mariozechner/pi-ai": "*",
    "@mariozechner/pi-coding-agent": "*",
    "@mariozechner/pi-tui": "*",
    "typebox": "*"
  },
  "pi": {
    "extensions": [
      "extensions/*.ts",
      "!extensions/themeMap.ts",
      "!extensions/research-tui.ts",
      "!extensions/research-tree.ts"
    ],
    "prompts": [
      "prompts/*.md"
    ],
    "skills": [
      "skills/*"
    ],
    "themes": [
      "themes/*.json"
    ]
  }
}